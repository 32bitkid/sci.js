{
  "name": "@4bitlabs/color-space",
  "version": "2.0.0",
  "description": "Utility functions for parsing, converting and mixing colors in sRGB, CIE-XYZ, CIE-L*a*b*, and okLab color spaces",
  "keywords": [
    "color",
    "colorspace",
    "srgb",
    "cie-xyz",
    "cie-lab",
    "oklab"
  ],
  "homepage": "https://github.com/32bitkid/sci.js/tree/main/libs/color-space#readme",
  "bugs": {
    "url": "https://github.com/32bitkid/sci.js/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/32bitkid/sci.js.git"
  },
  "license": "ISC",
  "author": "J. Holmes <j@holmes.codes>",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./srgb": {
      "types": "./dist/srgb/srgb.d.ts",
      "import": "./dist/srgb/srgb.js"
    },
    "./xyz": {
      "types": "./dist/xyz/xyz.d.ts",
      "import": "./dist/xyz/xyz.js"
    },
    "./lab": {
      "types": "./dist/lab/lab.d.ts",
      "import": "./dist/lab/lab.js"
    },
    "./oklab": {
      "types": "./dist/oklab/oklab.d.ts",
      "import": "./dist/oklab/oklab.js"
    },
    "./linear-rgb": {
      "types": "./dist/linear-rgb/linear-rgb.d.ts",
      "import": "./dist/linear-rgb/linear-rgb.js"
    }
  },
  "files": [
    "./dist/**/*"
  ],
  "scripts": {
    "build": "tsdown",
    "clean": "tsc --build --clean",
    "clean:wipe": "rimraf ./dist",
    "test": "vitest run",
    "test:dev": "vitest dev"
  }
}
