{
  "$schema": "https://biomejs.dev/schemas/2.5.4/schema.json",
  "files": {
    "includes": [
      "libs/**/*.js",
      "libs/**/*.ts",
      "!libs/**/dist",
      "!libs/**/coverage",
      "apps/**/*.js",
      "apps/**/*.ts",
      "!apps/**/dist",
      "!apps/**/coverage"
    ]
  },
  "linter": {
    "rules": {
      "correctness": {
        "useImportExtensions": {
          "level": "error",
          "options": {
            "extensionMappings": {
              "ts": "js",
              "tsx": "js"
            }
          }
        }
      }
    }
  },
  "formatter": {
    "indentStyle": "space"
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single"
    }
  },
  "assist": {
    "enabled": false
  }
}
